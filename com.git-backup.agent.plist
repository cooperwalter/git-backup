<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.git-backup.agent</string>
  <key>ProgramArguments</key>
  <array>
    <string>__INSTALL_DIR__/bin/git-backup-bash</string>
    <string>__INSTALL_DIR__/git-backup.sh</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>2</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>
  <key>StandardOutPath</key>
  <string>__HOME__/Library/Logs/git-backup.launchd.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/Library/Logs/git-backup.launchd.log</string>
</dict>
</plist>
